FROM debian:bullseye-slim
RUN apt-get update && \
    apt-get install -y --no-install-recommends  ca-certificates ceph-common  \
    e2fsprogs xfsprogs ebtables ethtool conntrack \
    iptables ipset bash kmod socat util-linux && \
    rm -rf /var/lib/apt/lists/*

# Copy the hyperkube binary
COPY ./kubernetes/_output/local/bin/linux/*/kube* /
